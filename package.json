{
    "name": "erpel",
    "description": "Free and libre alternative to Rambox and franz.",
    "version": "0.9.0",
    "main": ".vite/build/main.js",
    "scripts": {
        "start": "electron-forge start",
        "test": "vitest run --config vitest.node.config.ts && vitest run --config vitest.browser.config.ts",
        "test:browser": "vitest --config vitest.browser.config.ts",
        "test:node": "vitest --config vitest.node.config.ts",
        "test:coverage:node": "vitest run --config vitest.node.config.ts --coverage",
        "test:coverage:browser": "vitest run --config vitest.browser.config.ts --coverage",
        "test:coverage:merge": "mkdir -p ./coverage/temp && cp ./coverage/node/*.json ./coverage/temp/ && cp ./coverage/browser/*.json ./coverage/temp/ && mkdir -p ./coverage/merged && nyc merge ./coverage/temp ./coverage/merged/coverage-final.json",
        "test:coverage:report": "nyc report --reporter=html --reporter=text --report-dir=./coverage/html --temp-dir=./coverage/merged",
        "test:coverage:open": "xdg-open ./coverage/html/index.html",
        "test:coverage": "pnpm test:coverage:node && pnpm test:coverage:browser && pnpm test:coverage:merge && pnpm test:coverage:report",
        "make": "electron-forge make",
        "lint": "eslint",
        "tsc": "tsc --noEmit",
        "prettier": "prettier --write ."
    },
    "keywords": [],
    "author": {
        "name": "teruncius",
        "email": "teruncius@proton.me"
    },
    "license": "MIT",
    "devDependencies": {
        "@electron-forge/cli": "^7.11.1",
        "@electron-forge/maker-deb": "^7.11.1",
        "@electron-forge/maker-dmg": "^7.11.1",
        "@electron-forge/maker-rpm": "^7.11.1",
        "@electron-forge/maker-squirrel": "^7.11.1",
        "@electron-forge/maker-zip": "^7.11.1",
        "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
        "@electron-forge/plugin-fuses": "^7.11.1",
        "@electron-forge/plugin-vite": "^7.11.1",
        "@electron/fuses": "^1.8.0",
        "@eslint/js": "^9.39.4",
        "@pengx17/electron-forge-maker-appimage": "^1.2.1",
        "@react-spring/types": "^10.0.3",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/electron-squirrel-startup": "^1.0.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitest/browser": "^3.2.4",
        "@vitest/coverage-istanbul": "^3.2.4",
        "electron": "41.1.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.26",
        "globals": "^16.5.0",
        "memfs": "^4.57.1",
        "nyc": "^17.1.0",
        "playwright": "^1.58.2",
        "prettier": "^3.8.1",
        "prettier-plugin-organize-imports": "^4.3.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2",
        "vite": "^7.3.1",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.2.4",
        "vitest-browser-react": "^1.0.1"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@react-spring/web": "^10.0.3",
        "darkreader": "^4.9.120",
        "electron-squirrel-startup": "^1.0.1",
        "electron-vite": "^4.0.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.72.0",
        "react-router": "^7.13.2",
        "styled-components": "^6.3.12",
        "zod": "^4.3.6",
        "zustand": "^5.0.12"
    },
    "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8"
}
